@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Home - Smart Complaint Management System</PageTitle>

<div class="scms-hero-wrapper">
    <div class="container py-5">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge rounded-pill bg-primary-subtle text-primary mb-3">
                    <i class="fas fa-bolt me-1"></i>Digital complaint desk for modern cities & campuses
                </span>
                <h1 class="display-5 fw-bold mb-3">Handle every complaint with clarity, speed, and transparency.</h1>
                <p class="lead text-muted mb-4">
                    Smart Complaint Management System centralizes citizen and staff complaints, routes them
                    to the right team, and tracks every update on a clear, visual timeline and interactive map.
                </p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <!-- was: <a href="/create-complaint" ...> -->
                    <button class="btn btn-primary btn-lg" @onclick="OnRaiseComplaintClicked">
                        <i class="fas fa-plus me-1"></i>Raise a Complaint
                    </button>
                    <a class="btn btn-outline-primary btn-lg" href="/complaints">
                        <i class="fas fa-list me-1"></i>View Complaints
                    </a>
                    <a class="btn btn-outline-secondary btn-lg" href="/dashboard">
                        <i class="fas fa-tachometer-alt me-1"></i>View Analytics
                    </a>
                </div>
                <p class="small text-muted mb-0">
                    Built for municipalities, smart campuses, housing societies, and service teams that
                    care about fast resolutions and happy citizens.
                </p>
            </div>
            <div class="col-lg-5 text-center">
                <div class="scms-hero-card shadow-sm p-4 bg-white rounded-4">
                    <div class="mb-3">
                        <i class="fas fa-headset fa-3x text-primary me-3"></i>
                        <i class="fas fa-map-location-dot fa-3x text-success"></i>
                    </div>
                    <h5 class="fw-semibold mb-2">360° view of every complaint</h5>
                    <p class="small text-muted mb-3">
                        See who raised it, where it is, who owns it, and what changed—at a glance.
                    </p>
                    <ul class="list-unstyled small text-start mb-0 scms-hero-list">
                        <li><i class="fas fa-check text-success me-2"></i>Location-aware ticketing with GPS coordinates</li>
                        <li><i class="fas fa-check text-success me-2"></i>Role-based workflows for Admins &amp; Engineers</li>
                        <li><i class="fas fa-check text-success me-2"></i>Timeline, attachments, and activity history</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    <!-- What is SCM Section -->
    <div class="row mb-5 g-4 align-items-center">
        <div class="col-lg-6">
            <h2 class="h3 fw-bold mb-3">What is Smart Complaint Management?</h2>
            <p class="text-muted mb-3">
                Smart Complaint Management is a streamlined way to capture, route, and resolve complaints from
                citizens, employees, and customers. Instead of scattered messages and manual follow-ups, everything
                is tracked in a single workspace—prioritized, assigned, and monitored until closure.
            </p>
            <p class="text-muted mb-3">
                Our system supports web-based intake, role-based assignment, SLA tracking, and rich reporting so
                that every team member—from helpdesk staff to field engineers—knows exactly what to do next.
            </p>
            <ul class="list-unstyled text-muted mb-0">
                <li class="mb-2"><i class="fas fa-circle-notch text-primary me-2"></i>Centralized complaint inbox</li>
                <li class="mb-2"><i class="fas fa-circle-notch text-primary me-2"></i>Interactive complaint map</li>
                <li class="mb-2"><i class="fas fa-circle-notch text-primary me-2"></i>Status history and feedback loop</li>
            </ul>
        </div>
        <div class="col-lg-6">
            <div class="row g-3">
                <div class="col-sm-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="mb-3"><i class="fas fa-envelope-open-text fa-2x text-primary"></i></div>
                            <h6 class="fw-semibold mb-2">Multi-channel intake</h6>
                            <p class="small text-muted mb-0">Capture complaints from web forms and internal teams in a single queue ready for triage.</p>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="mb-3"><i class="fas fa-route fa-2x text-success"></i></div>
                            <h6 class="fw-semibold mb-2">Smart routing</h6>
                            <p class="small text-muted mb-0">Assign complaints to Admins or Engineers based on category, priority, and workload.</p>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="mb-3"><i class="fas fa-clock fa-2x text-warning"></i></div>
                            <h6 class="fw-semibold mb-2">SLA-friendly tracking</h6>
                            <p class="small text-muted mb-0">Monitor pending, in‑progress, and resolved complaints with clear timestamps.</p>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="mb-3"><i class="fas fa-chart-line fa-2x text-info"></i></div>
                            <h6 class="fw-semibold mb-2">Insights &amp; analytics</h6>
                            <p class="small text-muted mb-0">Use the dashboard and map to identify hotspots, recurring issues, and trends.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- How it works timeline -->
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="h3 fw-bold mb-3 text-center">How the complaint journey works</h2>
            <p class="text-muted text-center mb-4">From raising an issue to closing the loop, every step is transparent and traceable.</p>
            <div class="scms-flow-steps d-flex flex-column flex-md-row justify-content-between align-items-stretch gap-3">
                <div class="scms-flow-step">
                    <div class="scms-flow-icon bg-primary-subtle text-primary"><i class="fas fa-edit"></i></div>
                    <h6 class="fw-semibold mt-3 mb-2">1. Raise</h6>
                    <p class="small text-muted mb-0">Citizens or staff submit a complaint with photos, location, and category.</p>
                </div>
                <div class="scms-flow-step">
                    <div class="scms-flow-icon bg-info-subtle text-info"><i class="fas fa-share-alt"></i></div>
                    <h6 class="fw-semibold mt-3 mb-2">2. Assign</h6>
                    <p class="small text-muted mb-0">Admins assign to Engineers, Engineers can re-assign to Admins when escalation is needed.</p>
                </div>
                <div class="scms-flow-step">
                    <div class="scms-flow-icon bg-warning-subtle text-warning"><i class="fas fa-tools"></i></div>
                    <h6 class="fw-semibold mt-3 mb-2">3. Act</h6>
                    <p class="small text-muted mb-0">Field teams investigate, update status, and log progress notes and attachments.</p>
                </div>
                <div class="scms-flow-step">
                    <div class="scms-flow-icon bg-success-subtle text-success"><i class="fas fa-check-circle"></i></div>
                    <h6 class="fw-semibold mt-3 mb-2">4. Close &amp; learn</h6>
                    <p class="small text-muted mb-0">Complaints are resolved and the dashboard highlights patterns for long‑term fixes.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Audience / use cases -->
    <div class="row mb-5 g-4">
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-2"><i class="fas fa-city me-2 text-primary"></i>Municipal Corporations</h5>
                    <p class="small text-muted mb-3">Manage road, garbage, street‑light, and water leakage complaints on a single map.</p>
                    <ul class="small text-muted mb-0 list-unstyled">
                        <li class="mb-1"><i class="fas fa-check text-success me-2"></i>Ward‑wise performance</li>
                        <li class="mb-1"><i class="fas fa-check text-success me-2"></i>Evidence‑based closures</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-2"><i class="fas fa-school me-2 text-info"></i>Campuses &amp; townships</h5>
                    <p class="small text-muted mb-3">Give residents and students a simple way to report facility issues and track progress.</p>
                    <ul class="small text-muted mb-0 list-unstyled">
                        <li class="mb-1"><i class="fas fa-check text-success me-2"></i>Facility-wise complaint history</li>
                        <li class="mb-1"><i class="fas fa-check text-success me-2"></i>Role-based access for staff</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-2"><i class="fas fa-building me-2 text-success"></i>Service teams &amp; vendors</h5>
                    <p class="small text-muted mb-3">Track SLAs and field team performance across multiple sites or clients.</p>
                    <ul class="small text-muted mb-0 list-unstyled">
                        <li class="mb-1"><i class="fas fa-check text-success me-2"></i>Engineer workload visibility</li>
                        <li class="mb-1"><i class="fas fa-check text-success me-2"></i>Priority‑driven queues</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA band -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 scms-cta-band text-white">
                <div class="card-body d-flex flex-column flex-lg-row align-items-center justify-content-between gap-3">
                    <div>
                        <h4 class="fw-semibold mb-1"><i class="fas fa-users me-2"></i>Ready to modernize your complaint desk?</h4>
                        <p class="mb-0 small">Register, log in, and start managing complaints with dashboards, timelines, and maps in minutes.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="/register" class="btn btn-light">
                            <i class="fas fa-user-plus me-1"></i>Register Now
                        </a>
                        <a href="/login" class="btn btn-outline-light">
                            <i class="fas fa-sign-in-alt me-1"></i>Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .scms-hero-wrapper {
        background: radial-gradient(circle at top left, #e3f2fd 0, #f5f7fb 40%, #ffffff 100%);
    }

    .scms-hero-card {
        position: relative;
        overflow: hidden;
    }

    .scms-hero-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(13,110,253,0.08), transparent 55%);
        pointer-events: none;
    }

    .scms-hero-list li {
        margin-bottom: 0.35rem;
    }

    .scms-flow-steps {
        position: relative;
    }

    .scms-flow-step {
        flex: 1 1 0;
        background: #ffffff;
        border-radius: 0.75rem;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06);
        text-align: left;
    }

    .scms-flow-icon {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .scms-cta-band {
        background: linear-gradient(135deg, #0d6efd, #6610f2);
    }

    @@media (max-width: 767.98px) {
        .scms-flow-step {
            text-align: left;
        }
    }
</style>

@code {
    private async Task OnRaiseComplaintClicked()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            // Logged in → go directly to create complaint page
            Navigation.NavigateTo("/create-complaint");
        }
        else
        {
            // Not logged in → send to login
            Navigation.NavigateTo("/login");
        }
    }
}
