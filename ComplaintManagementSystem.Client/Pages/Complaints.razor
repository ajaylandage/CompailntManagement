@page "/complaints"
@using ComplaintManagementSystem.Shared.DTOs
@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Components.Authorization
@using ComplaintManagementSystem.Client.Services
@inject ComplaintManagementSystem.Client.Services.ComplaintService ComplaintService
@inject ComplaintManagementSystem.Client.Services.CategoryService CategoryService
@inject ComplaintManagementSystem.Client.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Complaints</PageTitle>

@if (!isAuthenticated)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 60vh;">
        <div class="text-center">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Checking authentication...</p>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>
            <i class="fas fa-list me-2"></i>
            @(isAdmin ? "All Complaints" : "My Complaints")
        </h3>
        <a href="/create-complaint" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Add Complaint
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h6 class="mb-0"><i class="fas fa-filter me-2"></i>Filter & Search</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Search Title</label>
                    <input class="form-control" placeholder="Enter complaint title..." @bind="search" @onkeypress="@(async (e) => { if (e.Key == "Enter") await OnSearchClicked(); })" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <InputSelect @bind-Value="selectedCategoryId" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <InputSelect @bind-Value="selectedStatusId" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="1">Pending</option>
                        <option value="2">Assigned</option>
                        <option value="3">In Progress</option>
                        <option value="4">Resolved</option>
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Priority</label>
                    <InputSelect @bind-Value="selectedPriority" class="form-select">
                        <option value="">All Priorities</option>
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-grid">
                        <button class="btn btn-primary" @onclick="OnSearchClicked">
                            <i class="fas fa-search me-1"></i>Search
                        </button>
                    </div>
                </div>
            </div>
            @if (HasActiveFilters())
            {
                <div class="mt-3">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">
                        <i class="fas fa-times me-1"></i>Clear Filters
                    </button>
                </div>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading complaints...</span>
            </div>
            <p class="mt-2">Loading complaints...</p>
        </div>
    }
    else if (!complaints.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                <h5>No Complaints Found</h5>
                <p class="text-muted">
                    @if (HasActiveFilters())
                    {
                        <span>No complaints match your current filters. Try adjusting your search criteria.</span>
                    }
                    else
                    {
                        <span>No complaints have been submitted yet.</span>
                    }
                </p>
                @if (!HasActiveFilters())
                {
                    <a href="/create-complaint" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Create First Complaint
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Found @complaints.Count complaint(s)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Created Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in complaints)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">#@c.Id</span></td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <a href="@($"/complaints/{c.Id}")" class="text-decoration-none fw-medium">
                                                @c.Title
                                            </a>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-primary">@c.CategoryName</span></td>
                                    <td>
                                        <span class="badge @GetPriorityBadgeClass(c.Priority)">
                                            <i class="fas @GetPriorityIcon(c.Priority) me-1"></i>@c.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(c.StatusName)">@c.StatusName</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@c.CreatedAt.ToString("MMM dd, yyyy")</small>
                                        <br />
                                        <small class="text-muted">@c.CreatedAt.ToString("hh:mm tt")</small>
                                    </td>
                                    <td>
                                        <a href="/complaints/@c.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<ComplaintListResponse> complaints = new();
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private bool isAdmin = false;

    private List<CategoryResponse> categories = new();
    private int? selectedCategoryId;
    private int? selectedStatusId;
    private string? selectedPriority;
    private string? search;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        isAuthenticated = true;
        isAdmin = JwtAuthenticationStateProvider.IsAdminPrincipal(authState.User);

        try
        {
            categories = (await CategoryService.GetCategoriesAsync()).ToList();
            await LoadComplaints();
        }
        catch (Exception)
        {
            // Handle error gracefully
            isLoading = false;
        }
    }

    private async Task LoadComplaints()
    {
        isLoading = true;
        try
        {
            complaints = await ComplaintService.GetComplaintsAsync(selectedStatusId, selectedCategoryId, selectedPriority, search);
        }
        catch (Exception)
        {
            // Handle error gracefully
            complaints = new List<ComplaintListResponse>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSearchClicked()
    {
        await LoadComplaints();
    }

    private async Task ClearFilters()
    {
        search = null;
        selectedCategoryId = null;
        selectedStatusId = null;
        selectedPriority = null;
        await LoadComplaints();
    }

    private bool HasActiveFilters()
    {
        return !string.IsNullOrEmpty(search) || selectedCategoryId.HasValue || selectedStatusId.HasValue || !string.IsNullOrEmpty(selectedPriority);
    }

    private string GetStatusBadgeClass(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "bg-warning text-dark",
            "assigned" => "bg-info",
            "in progress" => "bg-info",
            "resolved" => "bg-success",
            _ => "bg-secondary"
        };
    }

    private string GetPriorityBadgeClass(string priority)
    {
        return priority?.ToLower() switch
        {
            "low" => "bg-success",
            "medium" => "bg-warning text-dark",
            "high" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetPriorityIcon(string priority)
    {
        return priority?.ToLower() switch
        {
            "low" => "fa-arrow-down",
            "medium" => "fa-minus",
            "high" => "fa-arrow-up",
            _ => "fa-circle"
        };
    }
}
